# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` — it is gitignored for a reason.

# Local dev: SQLite file. Production (Vercel + Neon): Postgres URL injected by Vercel.
DATABASE_URL="file:./dev.db"

# Generate with: openssl rand -base64 32
# Must be the same across all running instances. Rotate = invalidates all sessions.
AUTH_SECRET=""

# "true" during initial setup so you can create your account.
# Set to "false" in Vercel env vars after your account exists to lock down signups.
ALLOW_SIGNUP="true"
